# Paths (relative to ~) that `./setup.sh --capture` should not report as
# unmanaged configs. Glob patterns supported. Silencing something here means
# "we know about it and chose not to track it" — new tools will still surface
# on their first appearance.

# Candidates we may track later — silenced for now, revisit deliberately
.claude
.claude.json
.config/ccstatusline
.config/gh
.config/opencode
.config/raycast
.config/zed

# Local bootstrap / override files (by design not stowed; see README)
.zshrc
.zshrc.local
.zprofile.local
.gitconfig.local

# Legacy shells and misc rc files we don't manage
.bashrc
.profile
.screenrc

# Auth, credentials, and secret-bearing state — never track
.agent-browser
.agent-slack
.aws
.awsvault
